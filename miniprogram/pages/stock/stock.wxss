/* pages/stock/stock.wxss */
.stock-container {
  padding: 24rpx;
  background-color: #f6f6f6;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.header-card {
  background-color: #fff;
  padding: 32rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  /* align-items: center; Remove center align */
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.added-badge {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #00A870;
  background-color: #e8f5e9;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: auto; /* Push to right if needed, but space-between handles it */
}

.stock-title-block {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.stock-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #333;
  line-height: 1.2;
}

.symbol-tag {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
  background-color: #f5f5f5;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin: 12rpx 0;
  justify-content: center; /* Center price */
}

.price {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.change-block {
  display: flex;
  align-items: center;
}

.change-text {
  font-size: 28rpx;
  font-weight: 600;
  margin-left: 4rpx;
}

.text-up { color: #E34D59; }
.text-down { color: #00A870; }

.time {
  font-size: 22rpx;
  color: #999;
}

/* Input Card */
.input-card {
  background-color: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #0052D9;
}

/* Chart Card */
.chart-card {
  background-color: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  height: 340rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.chart-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.trend-canvas {
  width: 100%;
  height: 260rpx;
}

/* AI Section */
.ai-section {
  background-color: #fff;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between; /* Adjusted */
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.empty-ai-card {
  padding: 40rpx;
  text-align: center;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  color: #999;
  font-size: 26rpx;
}

.ai-result-card {
  padding: 32rpx;
  border-radius: 16rpx;
  border: 1rpx solid transparent;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.bg-buy { 
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); 
  border-color: #a5d6a7; 
}
.bg-sell { 
  background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%); 
  border-color: #ef9a9a; 
}
.bg-hold { 
  background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%); 
  border-color: #bdbdbd; 
}

.ai-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.ai-action-text {
  font-size: 64rpx;
  font-weight: 900;
  text-transform: uppercase;
  color: #333;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.bg-buy .ai-action-text { color: #2e7d32; }
.bg-sell .ai-action-text { color: #c62828; }
.bg-hold .ai-action-text { color: #616161; }

.ai-trend {
  font-size: 28rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 12rpx;
}

.ai-reason {
  font-size: 28rpx;
  line-height: 1.6;
  color: #444;
  margin-bottom: 32rpx;
  background: rgba(255,255,255,0.5);
  padding: 16rpx;
  border-radius: 8rpx;
}

.ai-grid {
  display: flex;
  justify-content: space-between;
  background-color: rgba(255,255,255,0.8);
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.ai-time {
  font-size: 22rpx;
  color: #999;
  text-align: right;
  margin-top: 16rpx;
  font-style: italic;
}

.ai-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.ai-item:first-child {
  border-right: 1rpx solid rgba(0,0,0,0.1);
}

.ai-item .label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.ai-item .value {
  font-size: 36rpx;
  font-weight: bold;
  font-family: monospace;
}

.loss { color: #E34D59; }
.profit { color: #00A870; }

.mt-4 {
  margin-top: 32rpx;
}

.analysis-status {
  margin-top: 24rpx;
}

.status-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-top: 12rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}
