/* pages/me/me.wxss */
.me-container {
  padding: 24rpx;
  background-color: #f6f6f6;
  min-height: 100vh;
}

.user-card {
  background-color: #fff;
  padding: 48rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  margin-bottom: 32rpx;
}

.user-avatar {
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

.menu-list {
  margin-bottom: 32rpx;
}

.version-info {
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
  margin-top: 48rpx;
}

/* Popup Styles */
.login-popup {
  background-color: #fff;
  padding: 40rpx;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
}

.popup-header {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  background: none;
  padding: 0;
  width: 160rpx;
  height: 200rpx;
  margin: 0 auto 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrapper::after {
  border: none;
}

.avatar-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-bottom: 10rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999;
}

.nickname-wrapper {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  padding: 20rpx 0;
  margin-bottom: 60rpx;
}

.label {
  font-size: 30rpx;
  font-weight: bold;
  margin-right: 30rpx;
  width: 100rpx;
}

.nickname-input {
  flex: 1;
  font-size: 30rpx;
  height: 60rpx;
}
